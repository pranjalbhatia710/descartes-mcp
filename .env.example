# Descartes — bring your own keys. Copy to .env (which is gitignored) and fill in.
# NAMES ONLY here — never commit real keys. Every key is optional; missing keys
# degrade the run rather than break it.

# Panel mode: doubt across distinct Fireworks model families (disagreement = signal).
FIREWORKS_API_KEY=

# Grounding: resolve "world" doubts against cited Exa results.
EXA_API_KEY=

# Optional single-model "Claude alone" fallback when no MCP sampling is available.
OPENROUTER_API_KEY=

# ---- optional knobs (sensible defaults; uncomment to override) ----
# DESCARTES_PANEL_SIZE=3                       # 1 fast … N thorough (max = # of models)
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
# DESCARTES_TIMEOUT=45                         # per-model request timeout (seconds)
# DESCARTES_EXA_FLOOR=0.45                     # below this Exa confidence -> UNKNOWN
# DESCARTES_EXA_CACHE_TTL=3600                 # Exa result cache TTL (seconds)
